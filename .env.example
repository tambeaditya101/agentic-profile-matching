# ==============================================
# Agentic Profile Matching — Environment Config
# ==============================================
# All services below are FREE (free-tier or local).
# No paid accounts are required to run this project.
# ==============================================

# --- LLM Provider Fallback Chain ---
# The agent tries providers in this order:
#   1. Gemini Free Tier (if GEMINI_API_KEY is set and working)
#   2. Groq Free Tier   (if GROQ_API_KEY is set and working)
#   3. Ollama           (if installed locally)
#   4. Keyword fallback (always available, lower quality)
#
# Set BOTH Gemini and Groq keys for maximum reliability — if one's
# quota is exhausted, the other takes over automatically.

# --- Provider 1: Gemini Free Tier (primary) ---
# Get a free API key at: https://aistudio.google.com/apikey
# No credit card required. Free tier: 15 RPM, 1500 req/day.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Provider 2: Groq Free Tier (secondary, very fast) ---
# Get a free API key at: https://console.groq.com/keys
# No credit card required. Free tier: 30 RPM, 14400 req/day.
# Groq is ~5x faster than Gemini and has a much higher free quota.
# Recommended models: llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fast)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Provider 3: Ollama (offline fallback) ---
# If neither Gemini nor Groq is available, falls back to Ollama.
# Install Ollama at: https://ollama.com then run: ollama pull gemma2:9b
OLLAMA_MODEL=gemma2:9b

# --- Embeddings (fully local, no API key needed) ---
# ChromaDB's built-in ONNX embedding function uses all-MiniLM-L6-v2.
# Ships with ChromaDB — no extra install, no PyTorch, no download.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB (local embedded, no server needed) ---
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=resumes

# --- Resume data ---
RESUME_DIR=data/resumes

# --- Scoring weights ---
MUST_HAVE_WEIGHT=0.7
NICE_TO_HAVE_WEIGHT=0.3

# --- Screening thresholds ---
INITIAL_SCREEN_TOP_K=100
ROUND1_SHORTLIST_SIZE=10
ROUND2_SHORTLIST_SIZE=7
MIN_CANDIDATE_SCORE=0.3

# --- Conversation ---
MAX_CONVERSATION_TURNS=20
MESSAGE_WINDOW_SIZE=50